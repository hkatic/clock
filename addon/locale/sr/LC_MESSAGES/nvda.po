#. Translators: The message displayed after a countdown for an alarm has been chosen.
#: addon\globalPlugins\clock\clockSettingsGUI.py:523
#, python-brace-format
msgid "You've chosen an alarm to be triggered in {tm} {unit}"
msgstr "Izabrali ste alarm koji će se aktivirati za {tm} {unit}"

#. Translators: The title of the dialog which appears when the user has chosen to trigger an alarm.
#: addon\globalPlugins\clock\clockSettingsGUI.py:529
msgid "Confirmation"
msgstr "Potvrda"

#. Translators: A time formating (should be different from other time formattings)
#: addon\globalPlugins\clock\formats.py:78
#, python-brace-format
msgid "It's {hours} o'clock and {minutes} minutes"
msgstr "Sada je {hours} sati i {minutes} minuta"

#. Translators: A time formating (should be different from other time formattings)
#: addon\globalPlugins\clock\formats.py:80
#, python-brace-format
msgid "It's {hours} o'clock, {minutes} minutes and {seconds} seconds"
msgstr "Sada je {hours} sati, {minutes} minuta i {seconds} sekundi"

#. Translators: A time formating (should be different from other time formattings)
#: addon\globalPlugins\clock\formats.py:86
#, python-brace-format
msgid "{hours} o'clock, {minutes} minutes"
msgstr "{hours} sati, {minutes} minuta"

#. Translators: A time formating (should be different from other time formattings)
#: addon\globalPlugins\clock\formats.py:88
#, python-brace-format
msgid "{hours} o'clock, {minutes} minutes, {seconds} seconds"
msgstr "{hours} sati, {minutes} minuta, {seconds} sekundi"

#. Translators: A time formating (should be different from other time formattings)
#: addon\globalPlugins\clock\formats.py:94
#, python-brace-format
msgid "It's {minutes} past {hours}"
msgstr "Prošlo je {minutes} minuta posle {hours} sati"

#. Translators: A time formating (should be different from other time formattings)
#: addon\globalPlugins\clock\formats.py:96
#, python-brace-format
msgid "{hours} h {minutes} min"
msgstr "{hours} h {minutes} min"

#. Translators: A time formating (should be different from other time formattings)
#: addon\globalPlugins\clock\formats.py:98
#, python-brace-format
msgid "{hours} h, {minutes} min, {seconds} sec"
msgstr "{hours} h, {minutes} min, {seconds} sec"

#. Translators: A time formating (should be different from other time formattings)
#: addon\globalPlugins\clock\formats.py:100
#, python-brace-format
msgid "It's {hours}:{minutes}"
msgstr "Sada je {hours}:{minutes}"

#. Translators: A time formating (should be different from other time formattings)
#: addon\globalPlugins\clock\formats.py:102
#, python-brace-format
msgid "It's {hours}:{minutes}:{seconds}"
msgstr "Sada je {hours}:{minutes}:{seconds}"

#. Translators: A way to display 24-hour formats in the time display formats list in the settings panel.
#: addon\globalPlugins\clock\formats.py:120
#, python-brace-format
msgid "{fmt} (24-hour format)"
msgstr "{fmt} (24-časovni format)"

#. Translators: A way to display 12-hour formats in the time display formats list in the settings panel.
#: addon\globalPlugins\clock\formats.py:123
#, python-brace-format
msgid "{fmt} (12-hour format)"
msgstr "{fmt} (12-časovni format)"

