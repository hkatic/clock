#: addon\globalPlugins\clock\__init__.py:194
msgid "Allows you to schedule an alarm"
msgstr "Umožňuje nastaviť minutník"

#. Translators: Message presented in input help mode.
#: addon\globalPlugins\clock\__init__.py:259
msgid "Speaks current time. If pressed twice quickly, speaks current date. If pressed three times quickly, reports the current day, the week number, the current year and the days remaining before the end of the year."
msgstr "Oznamuje čas. Stlačené 2 krát oznamuje dátum. Stlačené 3 krát oznamuje aktuálny deň, číslo týždňa, aktuálny rok a počet dní zostávajúcich do konca roka."

#: addon\globalPlugins\clock\__init__.py:291
#, python-brace-format
msgid "Day {day}, week {week} of {year}, remaining days {remain}."
msgstr "Deň {day}, týždeň {week} rok {year}, počet dní do konca roka: {remain}."

#. Translators: Message presented in input help mode.
#: addon\globalPlugins\clock\__init__.py:335
msgid "Clock and calendar layer commands. After pressing this keystroke, press H for additional help."
msgstr "Príkazy pre rozšírené hodiny a kalendár. Po stlačení skratky stlačte h pre ďalšiu pomoc."

#. Translators: Message presented in input help mode.
#: addon\globalPlugins\clock\__init__.py:354
msgid "Starts, resets or stops the stopwatch."
msgstr "Spustí, vynuluje alebo zastaví stopky."

#: addon\globalPlugins\clock\__init__.py:363
msgid "Reset. Running."
msgstr "Vynulované. Beží."

#: addon\globalPlugins\clock\__init__.py:366
msgid "Running."
msgstr "Beží."

#: addon\globalPlugins\clock\__init__.py:369
#, python-brace-format
msgid "{0} stopped."
msgstr "{0} zastavené."

#. Translators: Message presented in input help mode.
#: addon\globalPlugins\clock\__init__.py:374
msgid "Speaks current stopwatch or count-down timer."
msgstr "Oznamuje čast stopiek alebo minutníka."

#. Translators: Message presented in input help mode.
#: addon\globalPlugins\clock\__init__.py:385
msgid "Gives the remaining and elapsed time before the next alarm."
msgstr "Oznámy uplynutý a zostávajúci čas minutníka"

#: addon\globalPlugins\clock\__init__.py:395
#: addon\globalPlugins\clock\__init__.py:498
#, python-brace-format
msgid "Elapsed time {elapsed}, remaining time {remaining}."
msgstr "Uplynulo {elapsed}, zostáva {remaining}."

#: addon\globalPlugins\clock\__init__.py:398
#: addon\globalPlugins\clock\__init__.py:414
#: addon\globalPlugins\clock\__init__.py:501
msgid "No alarm"
msgstr "Žiadny minutník"

#. Translators: Message presented in input help mode.
#: addon\globalPlugins\clock\__init__.py:404
msgid "Cancel the next alarm."
msgstr "Zruší aktuálny minutník."

#: addon\globalPlugins\clock\__init__.py:412
#: addon\globalPlugins\clock\__init__.py:495
msgid "Alarm cancelled"
msgstr "minutník zrušený"

#. Translators: Message presented in input help mode.
#: addon\globalPlugins\clock\__init__.py:420
msgid "Resets stopwatch to 0 without restarting it."
msgstr "Vynuluje a zastaví stopky."

#: addon\globalPlugins\clock\__init__.py:433
msgid "The stopwatch is already reset to 0. Use the clock layer command followed by s to start it."
msgstr "Stopky sú vynulované. Použite príkaz rozšírené hodiny a kalendár a stlačte s pre spustenie stopiek."

#: addon\globalPlugins\clock\__init__.py:438
msgid "Stopwatch reset."
msgstr "Stopky vynulované."

#. Translators: Message presented in input help mode.
#: addon\globalPlugins\clock\__init__.py:443
msgid "Lists available commands in clock command layer."
msgstr "Zobrazí príkazy dostupné po stlačení skratky rozšírené hodiny a kalendár."

#. Translators: Message presented in input help mode.
#: addon\globalPlugins\clock\__init__.py:461
msgid "Lists available commands in clock command layer, showing them in browse mode."
msgstr ""

#. Translators: Message presented in input help mode.
#: addon\globalPlugins\clock\__init__.py:484
msgid "Allows to check the next alarm. If pressed twice, cancels it."
msgstr "Skontroluje čas minutníka. Stlačené dvakrát minutník zastaví."

#. Translators: Message presented in input help mode.
#: addon\globalPlugins\clock\__init__.py:507
msgid "If an alarm is too long, allows to stop it."
msgstr "Zastaví minutník."

#: addon\globalPlugins\clock\__init__.py:513
msgid "No sound is launched."
msgstr "Nehrá žiadny zvuk."

#: addon\globalPlugins\clock\__init__.py:516
msgid "Sound stopped"
msgstr "Prehrávanie zastavené"

#. Translators: error message when attempting to open more than one alarm settings dialogs.
#: addon\globalPlugins\clock\__init__.py:530
msgid "Schedule alarms dialog is already open."
msgstr "Dialóg nastavenia minutníka je už otvorený."

#. Translators: Message presented in input help mode.
#: addon\globalPlugins\clock\__init__.py:537
msgid "Display the clock settings dialog box."
msgstr "Zobrazí dialóg nastavení rozšírených hodín a kalendára."

#. Translators: Message presented in input help mode.
#: addon\globalPlugins\clock\__init__.py:548
msgid "Display schedule alarms dialog box."
msgstr "Zobrazí dialóg nastavenia minutníka."

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-on store
#: buildVars.py:24
msgid "An advanced clock and calendar for NVDA.\n"
"NVDA+F12, get current time.\n"
"NVDA+F12 pressed twice quickly, get current date.\n"
"NVDA+F12 pressed three times quickly, reports the current day, the week number, the current year and the remaining days before the end of the year.\n"
"For other instructions, press  actions button in add-on store, then go to help."
msgstr ""

