msgstr "Elindítja, leállítja vagy újraindítja a stoppert"

#: addon\globalPlugins\clock\__init__.py:363
msgid "Reset. Running."
msgstr "Újraindítva. Fut."

#: addon\globalPlugins\clock\__init__.py:366
msgid "Running."
msgstr "Fut."

#: addon\globalPlugins\clock\__init__.py:369
#, python-brace-format
